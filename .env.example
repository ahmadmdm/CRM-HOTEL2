# ============================================================
# نظام إدارة الوحدات السكنية - متغيرات البيئة
# انسخ هذا الملف إلى .env وعدّل القيم
# ============================================================

# Application
ENVIRONMENT=development
APP_NAME="نظام إدارة الوحدات السكنية"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=false
REQUEST_ID_HEADER=X-Request-ID

# Database (PostgreSQL)
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=crm_db
DATABASE_URL=postgresql+asyncpg://crm_user:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/crm_db
DATABASE_SYNC_URL=postgresql://crm_user:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/crm_db

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# JWT Security — MUST change in production (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# CORS - comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# File Storage
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_THIS_NEXTAUTH_SECRET

# Initial Admin (created on first startup if no admin exists)
ADMIN_EMAIL=admin@crm.local
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
ADMIN_NAME=مدير النظام

# Demo data (optional for local development)
SEED_DEMO_DATA=false
DEMO_USER_PASSWORD=CHANGE_THIS_DEMO_PASSWORD
